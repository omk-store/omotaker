<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OMK Playlist</title>

<style>
body {
  margin: 0;
  overflow: hidden;
  font-family: Arial, sans-serif;
}

/* Video background */
video {
  position: fixed;
  width: 100%;
  height: 100%;
  object-fit: cover;
  top: 0;
  left: 0;
  z-index: -1;
}

/* Dark overlay */
.overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.4);
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Play button */
.play-btn {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.play-btn::after {
  content: "▶";
  font-size: 40px;
  color: black;
  margin-left: 6px;
}
</style>
</head>

<body>

<!-- VIDEO BACKGROUND -->
<video autoplay muted loop playsinline>
  <source src="https://raw.githubusercontent.com/omk-store/omotaker/main/omk-playlist-bg.mp4" type="video/mp4">
</video>

<div class="overlay">
  <!-- PLAY BUTTON (GOES TO SPOTIFY) -->
  <div class="play-btn" onclick="window.location.href='https://open.spotify.com/playlist/1Ox7VYqq4rFq1gYPPRP8Fh'"></div>
</div>

</body>
</html>