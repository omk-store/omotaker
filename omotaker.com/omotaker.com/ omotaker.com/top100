<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OMK Playlist</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #000;
  color: white;
  text-align: center;
}

/* Background image */
.hero {
  position: relative;
  height: 100vh;
  background: url('https://raw.githubusercontent.com/omk-store/omotaker/refs/heads/main/C9C79518-708B-42CC-9579-8E8559BD13F1.png') no-repeat center/cover;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Dark overlay */
.hero::after {
  content: "";
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
}

/* Content */
.content {
  position: relative;
  z-index: 2;
}

/* Play button */
.play-btn {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: auto;
  margin-bottom: 20px;
  cursor: pointer;
}

.play-btn::after {
  content: "▶";
  font-size: 30px;
  color: black;
  margin-left: 5px;
}

/* Buttons */
.links a {
  display: block;
  width: 220px;
  margin: 10px auto;
  padding: 12px;
  border-radius: 30px;
  text-decoration: none;
  font-weight: bold;
  color: white;
}

.spotify {
  background: #1DB954;
}

.apple {
  background: #fff;
  color: #000;
}

/* Title */
.title {
  font-size: 22px;
  margin-bottom: 15px;
}
</style>
</head>

<body>

<div class="hero">
  <div class="content">
    
    <div class="title">OMOTAKER PLAYLIST</div>

    <div class="play-btn" onclick="window.location.href='https://omotaker.com/playlist.html'"></div>

    <div class="links">
      <a href="https://open.spotify.com" class="spotify">Play on Spotify</a>
      <a href="https://music.apple.com/ng/playlist/everyday-vibe/pl.u-DdAN8l3TN2ANagg" class="apple">Play on Apple Music</a>
    </div>

  </div>
</div>

</body>
</html>