<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OMK Playlist</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  overflow: hidden;
}

/* Background image */
.bg {
  position: fixed;
  width: 100%;
  height: 100%;
  background: url('https://raw.githubusercontent.com/omk-store/omotaker/main/C9C79518-708B-42CC-9579-8E8559BD13F1.png') no-repeat center/cover;
}

/* Overlay */
.overlay {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  display: flex;
  justify-content: center;
  align-items: center;
}

/* Play button */
.play-btn {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
}

.play-btn::after {
  content: "▶";
  font-size: 40px;
  color: black;
  margin-left: 6px;
}
</style>
</head>

<body>

<div class="bg"></div>

<div class="overlay">
  <div class="play-btn" onclick="window.location.href='https://open.spotify.com/playlist/1Ox7VYqq4rFq1gYPPRP8Fh'"></div>
</div>

</body>
</html>